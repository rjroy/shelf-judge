{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun install",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; bunx prettier --write \"$f\" 2>/dev/null || true; }",
            "timeout": 30,
            "statusMessage": "Formatting..."
          }
        ]
      }
    ]
  }
}

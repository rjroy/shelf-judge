{
  "name": "shelf-judge",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/daemon",
    "packages/web",
    "packages/cli"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p packages/shared && tsc --noEmit -p packages/daemon",

    "test": "bun test"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.30.0",
    "eslint": "^9.24.0",
    "@eslint/js": "^9.24.0",
    "prettier": "^3.5.0",
    "bun-types": "^1.2.0"
  }
}
